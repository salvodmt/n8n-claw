# ============================================================
# n8n-claw — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- n8n ---
# Public n8n URL (updated to HTTPS by setup.sh if domain set)
N8N_URL=http://localhost:5678
# n8n URL from inside Docker network
N8N_INTERNAL_URL=http://172.17.0.1:5678
# Settings → API in n8n UI
N8N_API_KEY=your_n8n_api_key
# Updated to domain by setup.sh if domain set
N8N_HOST=localhost
# Set to "true" to skip nginx/Let's Encrypt (if using external reverse proxy)
SKIP_REVERSE_PROXY=
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678
# Auto-generated by setup.sh — DO NOT change after first run
N8N_ENCRYPTION_KEY=

# --- Supabase (Self-Hosted) ---
# Supabase Kong gateway URL
SUPABASE_URL=http://your-server:8000
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_role_key

# --- Telegram ---
# From @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token
# Your Telegram user ID
TELEGRAM_CHAT_ID=your_chat_id

# --- Anthropic ---
# claude-sonnet-4.x recommended
ANTHROPIC_API_KEY=your_anthropic_key

# --- Webhook API ---
# Auto-generated by setup.sh — used by Webhook Trigger + Adapter workflows
# External systems authenticate with this key via X-API-Key header
WEBHOOK_SECRET=

# --- n8n Credential Names (don't change unless you know what you're doing) ---
# These are the exact names used in the workflow JSON files
N8N_CREDENTIAL_ANTHROPIC_NAME=Anthropic API
N8N_CREDENTIAL_TELEGRAM_NAME=Telegram Bot
N8N_CREDENTIAL_POSTGRES_NAME=Supabase Postgres

# --- Optional: Embeddings (for RAG / vector memory) ---
# setup.sh writes these to DB (tools_config table) — workflows read from DB, not env
# Supported providers: openai, voyage, ollama
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
# Must match the vector column dimension in memory_long (default: 1536)
# EMBEDDING_DIM=1536
# Only for ollama provider:
# OLLAMA_URL=http://localhost:11434

# --- Optional: External Search ---
# For MCP Builder API docs search
BRAVE_API_KEY=your_brave_key
# SERP_API_KEY=your_serp_key

# --- Crawl4AI (Web Reader) ---
# Runs as Docker container, no external API key needed
# Set a token to protect the API (optional, internal-only access)
# CRAWL4AI_API_TOKEN=

# --- Optional: Nextcloud CalDAV ---
NEXTCLOUD_URL=https://your-nextcloud-instance
NEXTCLOUD_USER=your_user
NEXTCLOUD_PASS=your_password

# --- Optional: Vexa (Meeting Intelligence) ---
VEXA_URL=http://localhost:8056
VEXA_API_KEY=your_vexa_api_key
